#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_PATH="$ROOT_DIR/scripts/desloppify-local"
export DESLOPPIFY_CMD="$SCRIPT_PATH"

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo is required to run the local desloppify checkout." >&2
  exit 1
fi

exec cargo run --manifest-path "$ROOT_DIR/Cargo.toml" -p deslop-cli -- "$@"
